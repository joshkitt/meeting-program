{
    "name": "meeting-program",
    "version": "1.0.0",
    "private": true,
    "description": "",
    "scripts": {
        "build": "cross-env NODE_ENV=production next build src/app",
        "export": "dotenv -e .env -e .env-secure next export src/app",
        "dev": "nodemon -w src/server -r esm src/server/index.js",
        "start": "cross-env NODE_ENV=production node -r esm src/server/index.js",
        "storybook": "start-storybook -p 9999 -c .storybook",
        "verify": "npm run lint && npm run test",
        "lint": "eslint .",
        "test": "jest",
        "watch:test": "npm test -- --watch",
        "format": "prettier --write '**/*.{js,json,md}'"
    },
    "keywords": [],
    "license": "ISC",
