        "@lds/eden-headings": "^6.0.2",
        "@lds/eden-image": "^4.0.2",
        "@lds/eden-light-rays": "^4.0.4",
        "@lds/eden-page-wrapper": "^3.0.1",
        "@lds/eden-root": "^4.0.3",
        "@lds/eden-row": "^2.2.0",
        "@lds/eden-split": "^5.1.3",
        "@lds/eden-stack": "^5.1.0",
